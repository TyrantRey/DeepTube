# Google AI Studio (Gemini) API key for summarization / chat / mermaid.
# Acts as the server-wide default. Leave it blank to run in bring-your-own-key
# (BYOK) mode, where each user supplies their own key from the frontend settings
# (sent per request as the X-Gemini-Api-Key header). GET /config reports whether
# a user key is required (true when this is unset).
GOOGLE_API_KEY=...

# Optional overrides (defaults shown)
# GEMINI_MODEL=gemini-3.1-flash-lite
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
# DEFAULT_TRANSCRIPT_LANGUAGE=zh-Hant
# DATA_DIR=data
# KEEP_AUDIO=false
# SUMMARY_MAX_TOKENS=4096
# HISTORY_TOP_K=5
